#!/usr/bin/env bash
# Bank Account Verification Configuration
# 
# This script documents the environment variables needed for bank account verification
# in the offramp/initiate endpoint.

# Flutterwave API Configuration (for account verification)
export FLUTTERWAVE_SECRET_KEY="your_flutterwave_secret_key"
export FLUTTERWAVE_BASE_URL="https://api.flutterwave.com/v3"
export FLUTTERWAVE_TIMEOUT_SECS="30"

# Paystack API Configuration (for account verification)
export PAYSTACK_SECRET_KEY="your_paystack_secret_key"
export PAYSTACK_TIMEOUT_SECS="30"

# Bank Verification Service Configuration
export BANK_VERIFICATION_TIMEOUT_SECS="30"       # Timeout for account verification API calls
export BANK_VERIFICATION_MAX_RETRIES="2"         # Number of retries if verification fails
export BANK_VERIFICATION_NAME_MATCH_TOLERANCE="0.7"  # Name match threshold (0.0-1.0, 70% by default)

# Example: Looser name matching (will accept more variations)
# export BANK_VERIFICATION_NAME_MATCH_TOLERANCE="0.5"

# Example: Stricter name matching (must be more exact)
# export BANK_VERIFICATION_NAME_MATCH_TOLERANCE="0.9"

# System Wallet Configuration (for offramp)
export SYSTEM_WALLET_ADDRESS="GSYSTEMWALLETXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
export CNGN_ISSUER_ADDRESS="GCNGNISSUERXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
